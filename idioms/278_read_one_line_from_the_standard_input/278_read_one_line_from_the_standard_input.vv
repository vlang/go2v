module main

import io.util
import log
import os

fn main() {
	mut s := bufio.new_scanner(os.stdin())
	mut ok := s.scan()
	if !ok {
		log.fatal(s.err())
	}
	mut line := s.text()
	print('Read line: "${line}"\n')
}

fn init() {
	mut err := ioutil.write_file('/tmp/stdin', r'abc
  22
foo bar  '.bytes(), 644)
	if err != unsafe { nil } {
		panic(err)
	}
	os.stdin(), err = os.open('/tmp/stdin')
	if err != unsafe { nil } {
		panic(err)
	}
}
