module main

type TT = &i64

fn main() {
	mut a, b, c, d := i64(11), i64(22), i64(33), i64(11)
	mut x := [&b, &a, &b, &b, &c, &b, &a, &d]
	print(x)
	mut seen := map[string]bool{}
	mut j := isize(0)
	for _, v in x {
		if !seen[v] {
			x[j] = v
			j++
			seen[v] = true
		}
	}
	for i := j; i < x.len; i++ {
		x[i] = unsafe { nil }
	}
	x = x[..j]
	print(x)
}

fn print(a []TT) {
	mut glue := ''
	for _, p in a {
		print('${glue}${*p:d}')
		glue = ', '
	}
	println()
}
