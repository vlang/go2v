module main

fn main() {
	mut mymap := {
		'one':   1
		'two':   2
		'three': 3
		'four':  4
		'dos':   2
		'deux':  2
	}

	mut entries := []Entry{len: 0, cap: mymap.len}
	for k, x in mymap {
		entries << Entry{
			key:   k
			value: x
		}
	}
	entries.sort()
	for _, e in entries {
		println('Key = ${e.key} , Value = ${e.value}')
	}
}
