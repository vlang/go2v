module main

import io.util
import os

fn main() {
	for _, filepath in ['/tmp/foo.txt', '/tmp/bar.txt', '/tmp/foo.txt'] {
		mut err := os.remove(filepath)
		if err == unsafe { nil } {
			println('Removed ${filepath}')
		} else {
			(os.stderr()).write_string('${err}\n') or { 0 }
		}
	}
}

fn init() {
	mut err := ioutil.write_file('/tmp/foo.txt', r'abc'.bytes(), 644)
	if err != unsafe { nil } {
		panic(err)
	}
}
