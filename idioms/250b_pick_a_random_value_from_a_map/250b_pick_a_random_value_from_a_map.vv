module main

import rand

type KK = string
type VV = string

fn pick(m map[string]VV) VV {
	mut k := rand.intn(m.len)
	for _, x in m {
		if k == 0 {
			return x
		}
		k--
	}
	panic('unreachable')
}

fn main() {
	mut m := {
		'one':   'un'
		'two':   'deux'
		'three': 'trois'
		'four':  'quatre'
	}
	mut x := pick(m)
	println(x)
}
