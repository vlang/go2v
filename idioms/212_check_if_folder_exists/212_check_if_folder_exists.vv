module main

import os

fn main() {
	mut path := 'foo'
	mut info, err := os.stat(path)
	mut b := !os.is_not_exist(err) && info.is_dir()
	println('${path} is a directory: ${b}')
	err = os.mkdir(path, os.mode_dir)
	if err != unsafe { nil } {
		panic(err)
	}
	info, err = os.stat(path)
	b = !os.is_not_exist(err) && info.is_dir()
	println('${path} is a directory: ${b}')
}
