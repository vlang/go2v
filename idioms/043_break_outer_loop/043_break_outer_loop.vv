module main

import os

__global m = [[isize(1), 2, 3], [isize(11), 0, 30], [isize(5), -20, 55],
	[isize(0), 0, -60]]

fn main() {
	mainloop: for i, line in m {
		(os.stderr()).write_string('Searching in line ${i}\n') or { 0 }
		for _, v in line {
			if v < 0 {
				println('Found  ${v}')
				break mainloop
			}
		}
	}
	println('Done.')
}
