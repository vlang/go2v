module main

import io.util
import os

pub const f = '/tmp/data.txt'

fn init() {
	mut err := ioutil.write_file(f, 'abcdefghij'.bytes(), 644)
	if err != unsafe { nil } {
		panic(err)
	}
}

fn main() {
	mut position := i64(5)
	mut err := os.truncate(f, position)
	if err != unsafe { nil } {
		panic(err)
	}
	mut buffer, err_1 := ioutil.read_file(f)
	if err_1 != unsafe { nil } {
		panic(err_1)
	}
	print('${f} has length ${buffer.len:d} and contents "${buffer}"\n')
}
