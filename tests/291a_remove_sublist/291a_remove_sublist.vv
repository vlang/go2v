module main

type TT = &string

fn main() {
	mut items := [new_t('a'), new_t('b'), new_t('c'), new_t('d'),
		new_t('e')]
	mut i, j := isize(2), isize(4)
	copy(items[i..], items[j..])
	for k, n := items.len - j + i, items.len; k < n; k++ {
		items[k] = unsafe { nil }
	}
	items = items[..items.len - j + i]
	for item in items {
		println(*item)
	}
}

fn new_t(s string) TT {
	return &s
}
