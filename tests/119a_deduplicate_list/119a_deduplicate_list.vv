module main

fn main() {
	mut x := ['b', 'a', 'b', 'c']
	println('x = ${x}')
	mut y := map[string]_VAnonStruct1{}
	for v in x {
		y[v] = struct {}
		{}
	}
	mut x2 := []T{len: 0, cap: y.len}
	for v_1 in x {
		ok := v_1 in y
		if ok {
			x2 << v_1
			y.delete(v_1)
		}
	}
	x = x2
	println('x = ${x}')
}
