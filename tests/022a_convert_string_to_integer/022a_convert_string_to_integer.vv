module main

import reflect
import strconv

fn main() {
	mut s := '123'
	println(s)
	println('type: ${reflect.type_of(s)}')
	mut err_ok := true
	i := strconv.atoi(s) or {
		err_ok = false
		0
	}
	err := if err_ok { none } else { error('conversion failed') }
	if err != none {
		panic(err)
	}
	println(i)
	println('type: ${reflect.type_of(i)}')
}
