module main

import io.util
import log
import os

fn main() {
	mut lines := []string{}

	mut s := bufio.new_scanner(os.stdin())
	for s.scan() {
		mut line := s.text()
		lines << line
	}
	mut err := s.err()
	if !isnil(err) {
		log.fatal(err)
	}
	print('Read ${lines.len} lines\n')
	print('"${lines}"')
}

fn init() {
	mut data := r'abc
  22
foo bar  '
	mut err := ioutil.write_file('/tmp/stdin', data.bytes(), 644)
	if !isnil(err) {
		panic(err)
	}
	os.stdin(), err = os.open('/tmp/stdin')
	if !isnil(err) {
		panic(err)
	}
}
