module main

// NewSquareMatrix creates a N-by-N matrix
pub fn new_square_matrix(n isize) ([][]f64, IError) {
	if n < 0 {
		return unsafe { nil }, error('Invalid size ${n}: order cannot be negative')
	}
	mut matrix := [][]f64{len: n}
	for i, _ in matrix {
		matrix[i] = []f64{len: n}
	}
	return matrix, unsafe { nil }
}

fn main() {
	mut n1 := isize(3)
	mut matrix1, err1 := new_square_matrix(n1)
	if isnil(err1) {
		println(matrix1)
	} else {
		println(err1)
	}
	mut n2 := -2
	mut matrix2, err2 := new_square_matrix(n2)
	if isnil(err2) {
		println(matrix2)
	} else {
		println(err2)
	}
}
