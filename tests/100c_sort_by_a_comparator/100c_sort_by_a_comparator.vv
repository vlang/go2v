module main

pub struct Item {
pub mut:
	label string
	p     isize
	lang  string
}

// c returns true if x is "inferior to" y (in a custom way)
fn c(x Item, y Item) bool {
	return x.p < y.p
}

fn main() {
	mut items := [Item{'twelve', 12, 'english'}, Item{'six', 6, 'english'},
		Item{'eleven', 11, 'english'}, Item{'zero', 0, 'english'},
		Item{'two', 2, 'english'}]
	println('Unsorted:  ${items}')
	items.sort()
	println('Sorted:  ${items}')
}
