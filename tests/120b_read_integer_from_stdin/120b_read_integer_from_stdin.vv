module main

import io.util
import os
// This string simulates the keyboard entry.

__global user_input string

fn main() {
	mut i := 0

	_, err := 0
	println('${i} ${err}')
	mut j := 0

	_, err = 0
	println('${j} ${err}')
}

// The Go Playground doesn't actually read os.Stdin, so this
// workaround writes some data on virtual FS in a file, and then
// sets this file as the new Stdin.
//
// Note that the init func is run before main.
fn init() {
	mut err := ioutil.write_file('/tmp/stdin', user_input.bytes(), 644)
	if !isnil(err) {
		panic(err)
	}
	mut file_in, err_1 := os.open('/tmp/stdin')
	if !isnil(err_1) {
		panic(err_1)
	}
	os.stdin() = file_in
}
